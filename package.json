{
  "name": "ts-bench",
  "version": "1.1.0",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "test": "bun test ./src",
    "typecheck": "bunx --bun tsc -p . --noEmit",
    "build:swelancer-pages": "bun scripts/build-swelancer-pages.ts repos/frontier-evals/project/swelancer/all_swelancer_tasks.csv",
    "build:results-pages": "bun scripts/build-results-pages.ts",
    "build:site": "bun scripts/build-site.ts",
    "build:all": "bun scripts/build-results-pages.ts && bun scripts/build-swelancer-pages.ts repos/frontier-evals/project/swelancer/all_swelancer_tasks.csv && bun scripts/build-site.ts",
    "serve": "bun x serve docs"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "csv-parse": "^6.1.0"
  }
}
